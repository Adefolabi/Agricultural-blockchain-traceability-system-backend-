# Server
PORT=3000
NODE_ENV=development

# CORS - comma-separated allowed origins (restrict in production)
CORS_ORIGIN=http://localhost:3000

# JWT - JWT_SECRET is required when NODE_ENV=production
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=24h

# Fabric Network
CHANNEL_NAME=mychannel
CHAINCODE_NAME=traceability

# Fabric Crypto Material (test-network paths)
CRYPTO_PATH=../../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com
CERT_PATH=${CRYPTO_PATH}/users/User1@org1.example.com/msp/signcerts/cert.pem
KEY_DIR_PATH=${CRYPTO_PATH}/users/User1@org1.example.com/msp/keystore
TLS_CERT_PATH=${CRYPTO_PATH}/peers/peer0.org1.example.com/tls/ca.crt

# Peer and Orderer
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com
MSP_ID=Org1MSP
